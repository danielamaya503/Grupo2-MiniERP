@model TechCore.Models.DTO.Dashboards.BodegaDashboardDTO

@{
    ViewData["Title"] = "Dashboard Bodega";
    ViewData["Active"] = "Dashboard";
}

<div class="space-y-8">

    @* ── Encabezado ───────────────────────────────────────── *@
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-3xl font-black tracking-tight text-slate-900 dark:text-slate-100">
                Dashboard de Bodega
            </h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1">
                Control integral de existencias.
            </p>
        </div>
       
    </div>

    @* ── Alertas TempData ─────────────────────────────────── *@
    @if (TempData["Exito"] != null)
    {
        <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <p class="text-sm font-bold text-emerald-700">@TempData["Exito"]</p>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-red-600">cancel</span>
            <p class="text-sm font-bold text-red-700">@TempData["Error"]</p>
        </div>
    }

    @* ══════════════════════════════════════════════════════ *@
    @* KPI CARDS                                             *@
    @* ══════════════════════════════════════════════════════ *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

        @* Total Productos *@
        <div class="bg-white dark:bg-slate-900 p-5 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Total Productos</p>
            <h3 class="text-3xl font-black mt-1 text-slate-900 dark:text-white">
                @Model.TotalProductos.ToString("N0")
            </h3>
            <div class="mt-2 text-xs text-primary font-medium flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">category</span>
                Productos activos en sistema
            </div>
        </div>

        @* Valor Inventario *@
        <div class="bg-white dark:bg-slate-900 p-5 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Valor Inventario</p>
            <h3 class="text-3xl font-black mt-1 text-slate-900 dark:text-white">
                $@Model.ValorInventario.ToString("N2")
            </h3>
            <div class="mt-2 text-xs text-primary font-medium flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">payments</span>
                Basado en precio de compra
            </div>
        </div>

        @* Stock Bajo *@
        <div class="@(Model.ItemsStockBajo > 0 ? "bg-red-50 dark:bg-red-900/10 border-red-100 dark:border-red-900/30" : "bg-white dark:bg-slate-900 border-slate-200 dark:border-slate-800") p-5 rounded-xl border shadow-sm">
            <p class="text-xs font-bold @(Model.ItemsStockBajo > 0 ? "text-red-500/80" : "text-slate-400") uppercase tracking-wider">
                Stock Bajo
            </p>
            <h3 class="text-3xl font-black mt-1 @(Model.ItemsStockBajo > 0 ? "text-red-600 dark:text-red-400" : "text-slate-900 dark:text-white")">
                @Model.ItemsStockBajo <span class="text-lg font-bold">ítems</span>
            </h3>
            <div class="mt-2 text-xs @(Model.ItemsStockBajo > 0 ? "text-red-500" : "text-primary") font-medium flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">
                    @(Model.ItemsStockBajo > 0 ? "priority_high" : "check_circle")
                </span>
                @(Model.ItemsStockBajo > 0 ? "Acción requerida" : "Stock en buen estado")
            </div>
        </div>

    </div>

    @* ══════════════════════════════════════════════════════ *@
    @* GRID PRINCIPAL — Alertas + Compras recientes          *@
    @* ══════════════════════════════════════════════════════ *@
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        @* ── COLUMNA IZQUIERDA — Alertas de stock ────────── *@
        <div class="lg:col-span-1 space-y-4">

            <div class="flex items-center justify-between">
                <h2 class="text-base font-bold flex items-center gap-2 text-slate-800 dark:text-slate-100">
                    <span class="material-symbols-outlined text-red-500">warning</span>
                    Alertas de Stock Bajo
                </h2>
                <a asp-controller="Producto" asp-action="Index"
                       class="text-sm text-primary font-semibold hover:underline">
                    Ver todo
                </a>
            </div>

            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">

                @if (!Model.AlertasStock.Any())
                {
                    <div class="p-8 flex flex-col items-center gap-2 text-center">
                        <span class="material-symbols-outlined text-4xl text-emerald-400">inventory</span>
                        <p class="text-sm font-semibold text-slate-600 dark:text-slate-300">
                            Todo el stock está en orden
                        </p>
                        <p class="text-xs text-slate-400">No hay productos por debajo del mínimo</p>
                    </div>
                }
                else
                {
                    <div class="divide-y divide-slate-100 dark:divide-slate-800">
                        @foreach (var alerta in Model.AlertasStock)
                        {
                            <div class="p-4 flex items-center justify-between hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                <div class="flex items-center gap-3 min-w-0">
                                    <div class="size-10 rounded-lg bg-red-50 dark:bg-red-900/20 flex-shrink-0 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-red-400 text-[18px]">
                                            inventory_2
                                        </span>
                                    </div>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-slate-900 dark:text-white truncate">
                                            @alerta.Descripcion
                                        </p>
                                        <p class="text-xs text-slate-400 font-mono">@alerta.CodProd</p>
                                    </div>
                                </div>
                                <div class="text-right flex-shrink-0 ml-3">
                                    <p class="text-sm font-black @(alerta.Stock == 0 ? "text-red-700" : "text-red-500")">
                                        @alerta.Stock uni.
                                    </p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase">
                                        Mín: @alerta.StockMinimo
                                    </p>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="p-3 bg-slate-50 dark:bg-slate-800/50 text-center border-t border-slate-100 dark:border-slate-800">
                        <a asp-controller="Compra" asp-action="Index"
                               class="text-xs font-bold text-primary uppercase tracking-widest hover:text-primary/80">
                            Generar Orden de Compra
                        </a>
                    </div>
                }

            </div>
        </div>

        @* ── COLUMNA DERECHA — Compras recientes ─────────── *@
        <div class="lg:col-span-2 space-y-4">

            <div class="flex items-center justify-between">
                <h2 class="text-base font-bold flex items-center gap-2 text-slate-800 dark:text-slate-100">
                    <span class="material-symbols-outlined text-primary">shopping_cart</span>
                    Compras Recientes
                </h2>
                <a asp-controller="Compra" asp-action="Index"
                       class="text-sm text-primary font-semibold hover:underline flex items-center gap-1">
                    Ver todas
                </a>
            </div>

            <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">

                @if (!Model.ComprasRecientes.Any())
                {
                    <div class="p-12 flex flex-col items-center gap-2 text-center">
                        <span class="material-symbols-outlined text-4xl text-slate-300">receipt_long</span>
                        <p class="text-sm font-semibold text-slate-600 dark:text-slate-300">
                            No hay compras registradas
                        </p>
                    </div>
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wider">Orden</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wider">Proveedor</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wider hidden md:table-cell">Fecha</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wider">Total</th>
                                    <th class="px-4 py-3 text-xs font-bold text-slate-400 uppercase tracking-wider text-center">Estado</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                                @foreach (var compra in Model.ComprasRecientes)
                                {
                                    @* Inicial del proveedor para el avatar *@
                                    var inicial = compra.Proveedor.Length > 0
                                        ? compra.Proveedor.Substring(0, 2).ToUpper()
                                        : "??";

                                    @* Badge de estado *@
                                    var (badgeBg, badgeText, estadoLabel) = compra.Estado == 1
                                        ? ("bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400", "", "Recibido")
                                        : ("bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400", "", "Cancelado");

                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                        <td class="px-4 py-3 text-sm font-bold text-slate-900 dark:text-white font-mono">
                                            #@compra.NOrden
                                        </td>
                                        <td class="px-4 py-3">
                                            <div class="flex items-center gap-2">
                                                <div class="size-7 rounded-full bg-primary/20 flex-shrink-0 flex items-center justify-center text-[10px] font-black text-primary">
                                                    @inicial
                                                </div>
                                                <span class="text-sm text-slate-700 dark:text-slate-300 truncate max-w-[120px]">
                                                    @compra.Proveedor
                                                </span>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-slate-500 hidden md:table-cell">
                                            @compra.Fecha.ToString("dd MMM, yyyy")
                                        </td>
                                        <td class="px-4 py-3 text-sm font-bold text-slate-900 dark:text-white">
                                            $@compra.Total.ToString("N2")
                                        </td>
                                        <td class="px-4 py-3 text-center">
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase @badgeBg">
                                                @estadoLabel
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

