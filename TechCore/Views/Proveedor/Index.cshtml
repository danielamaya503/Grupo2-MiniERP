@model TechCore.Models.DTO.Proveedor.ProveedorPaginadoDTO
@{
    ViewData["Title"] = "Proveedores";
    ViewData["Active"] = "Proveedores";
}

<div class="space-y-8">

    @* ── Encabezado ──────────────────────────────────────────────────── *@
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-3xl font-black tracking-tight text-slate-900 dark:text-white">
                Proveedores
            </h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1">
                Gestión de proveedores y datos de contacto.
            </p>
        </div>

        @if (User.IsInRole("Administrador"))
        {
            <button onclick="abrirModalCrear()"
                    class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white
                px-6 py-3 rounded-lg font-bold transition-all shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined">add_business</span>
                Nuevo Proveedor
            </button>
        }
        

    </div>

    @* ── Alertas TempData ─────────────────────────────────────────────── *@
    @if (TempData["Exito"] != null)
    {
        <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <p class="text-sm font-bold text-emerald-700">@TempData["Exito"]</p>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-red-600">cancel</span>
            <p class="text-sm font-bold text-red-700">@TempData["Error"]</p>
        </div>
    }

    @* ── Búsqueda ─────────────────────────────────────────────────────── *@
    <form method="get"
          class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200
        dark:border-slate-800 shadow-sm">
        <div class="flex flex-col sm:flex-row gap-3">
            <div class="flex-1 flex items-center bg-slate-50 dark:bg-slate-800
                border border-slate-200 dark:border-slate-700 rounded-lg px-3">
                <span class="material-symbols-outlined text-slate-400 text-xl">search</span>
                <input type="text" name="busqueda" value="@Model.Busqueda"
                       placeholder="Buscar por código o nombre…"
                       class="bg-transparent border-none focus:ring-0 text-sm w-full py-2 px-2" />
            </div>
            <button type="submit"
                    class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90
                text-white px-5 py-2.5 rounded-lg font-semibold transition-all">
                <span class="material-symbols-outlined text-sm">search</span>
                Buscar
            </button>
            @if (!string.IsNullOrEmpty(Model.Busqueda))
            {
                <a href="?"
                       class="inline-flex items-center gap-2 border border-slate-200 dark:border-slate-700
                    text-slate-500 hover:bg-slate-50 px-5 py-2.5 rounded-lg font-semibold
                    transition-all">
                    <span class="material-symbols-outlined text-sm">close</span>
                    Limpiar
                </a>
            }
        </div>
    </form>

    @* ── Tabla ────────────────────────────────────────────────────────── *@
    @if (!Model.Proveedores.Any())
    {
        <div class="py-20 flex flex-col items-center gap-3 text-center">
            <span class="material-symbols-outlined text-6xl text-slate-200">local_shipping</span>
            <p class="text-lg font-bold text-slate-500">No se encontraron proveedores</p>
            @if (!string.IsNullOrEmpty(Model.Busqueda))
            {
                <p class="text-sm text-slate-400">
                    Intenta con otro término de búsqueda
                </p>
            }
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200
            dark:border-slate-800 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-100 dark:border-slate-800
                            bg-slate-50 dark:bg-slate-800/50
                            text-xs text-slate-500 uppercase tracking-widest">
                            <th class="px-5 py-3.5 text-left font-bold">Código</th>
                            <th class="px-5 py-3.5 text-left font-bold">Nombre</th>
                            <th class="px-5 py-3.5 text-left font-bold hidden md:table-cell">
                                Teléfono
                            </th>
                            <th class="px-5 py-3.5 text-left font-bold hidden lg:table-cell">
                                Correo
                            </th>
                            <th class="px-5 py-3.5 text-left font-bold hidden xl:table-cell">
                                Dirección
                            </th>
                            <th class="px-5 py-3.5 text-left font-bold hidden sm:table-cell">
                                Registrado
                            </th>
                            <th class="px-5 py-3.5 text-right font-bold">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                        @foreach (var p in Model.Proveedores)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/40 transition-colors group">
                                <td class="px-5 py-3.5">
                                    <span class="font-mono text-xs font-bold text-primary
                                        bg-primary/10 px-2 py-1 rounded">
                                        @p.Codprovee
                                    </span>
                                </td>
                                <td class="px-5 py-3.5 font-bold text-slate-900 dark:text-white">
                                    @p.Nombre
                                </td>
                                <td class="px-5 py-3.5 text-slate-500 hidden md:table-cell">
                                    @(string.IsNullOrEmpty(p.Telefono) ? "—" : p.Telefono)
                                </td>
                                <td class="px-5 py-3.5 text-slate-500 hidden lg:table-cell">
                                    @(string.IsNullOrEmpty(p.Email) ? "—" : p.Email)
                                </td>
                                <td class="px-5 py-3.5 text-slate-500 hidden xl:table-cell
                                    max-w-[200px] truncate">
                                    @(string.IsNullOrEmpty(p.Direccion) ? "—" : p.Direccion)
                                </td>
                                <td class="px-5 py-3.5 text-slate-400 text-xs hidden sm:table-cell">
                                    @p.CreatedDate?.ToString("dd/MM/yyyy")
                                </td>
                                <td class="px-5 py-3.5">
                                    <div class="flex items-center justify-end gap-1">
                                        <button onclick="abrirModalEditar(
                                            '@p.Codprovee',
                                            '@Html.Raw(p.Nombre.Replace("'", "\\'"))',
                                            '@Html.Raw((p.Telefono ?? "").Replace("'", "\\'"))',
                                            '@Html.Raw((p.Email ?? "").Replace("'", "\\'"))',
                                            '@Html.Raw((p.Direccion ?? "").Replace("'", "\\'"))')"
                                                title="Editar"
                                                class="p-2 rounded-lg text-slate-400
                                            hover:bg-primary/10 hover:text-primary
                                            transition-colors">
                                            <span class="material-symbols-outlined text-xl">edit</span>
                                        </button>
                                        <button onclick="abrirModalDesactivar(
                                            '@p.Codprovee',
                                            '@Html.Raw(p.Nombre.Replace("'", "\\'"))')"
                                                title="Desactivar"
                                                class="p-2 rounded-lg text-slate-400
                                            hover:bg-red-50 hover:text-red-500
                                            transition-colors">
                                            <span class="material-symbols-outlined text-xl">block</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Footer tabla: conteo + paginación *@
            <div class="flex items-center justify-between px-5 py-3.5
                border-t border-slate-100 dark:border-slate-800">
                <p class="text-sm text-slate-500">
                    <span class="font-bold text-slate-900 dark:text-white">
                        @Model.TotalRegistros
                    </span> proveedor(es)
                    @if (!string.IsNullOrEmpty(Model.Busqueda))
                    {
                        <span>
                            para
                            "<span class="font-bold text-primary">@Model.Busqueda</span>"
                        </span>
                    }
                </p>

                @if (Model.TotalPaginas > 1)
                {
                    <div class="flex items-center gap-1">
                        @if (Model.TienePaginaAnterior)
                        {
                            <a asp-action="Index"
                                   asp-route-pagina="@(Model.PaginaActual - 1)"
                                   asp-route-busqueda="@Model.Busqueda"
                                   class="p-1.5 rounded-lg text-slate-400 hover:bg-slate-100
                                transition-colors">
                                <span class="material-symbols-outlined text-base">chevron_left</span>
                            </a>
                        }
                        @for (int i = Math.Max(1, Model.PaginaActual - 2);
                                                          i <= Math.Min(Model.TotalPaginas, Model.PaginaActual + 2); i++)
                        {
                            <a asp-action="Index"
                                   asp-route-pagina="@i"
                                   asp-route-busqueda="@Model.Busqueda"
                                   class="w-8 h-8 flex items-center justify-center rounded-lg
                                text-xs font-bold transition-colors
                                @(i == Model.PaginaActual
                                                                   ? "bg-primary text-white"
                                                                   : "text-slate-500 hover:bg-slate-100")">
                                @i
                            </a>
                        }
                        @if (Model.TienePaginaSiguiente)
                        {
                            <a asp-action="Index"
                                   asp-route-pagina="@(Model.PaginaActual + 1)"
                                   asp-route-busqueda="@Model.Busqueda"
                                   class="p-1.5 rounded-lg text-slate-400 hover:bg-slate-100
                                transition-colors">
                                <span class="material-symbols-outlined text-base">chevron_right</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@* ══════════════════════════════════════════════════════════════════════
   MODAL — CREAR
   ══════════════════════════════════════════════════════════════════════ *@
<div id="modalCrear"
     class="fixed inset-0 z-50 hidden items-center justify-center
    bg-black/50 backdrop-blur-sm p-4">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-lg">

        <div class="flex items-center justify-between px-6 py-4
            border-b border-slate-100 dark:border-slate-800">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white
                flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">add_business</span>
                Nuevo Proveedor
            </h3>
            <button onclick="cerrarModal('modalCrear')"
                    class="text-slate-400 hover:text-slate-600 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <form asp-controller="Proveedor" asp-action="Crear" method="post"
              class="p-6 space-y-4">
            @Html.AntiForgeryToken()

            @* Código autogenerado (solo lectura) *@
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase
                    tracking-widest mb-1.5">
                    Código (autogenerado)
                </label>
                <div class="flex items-center gap-2 bg-slate-50 dark:bg-slate-800
                    border border-slate-200 dark:border-slate-700
                    rounded-lg px-3 py-2.5">
                    <span class="material-symbols-outlined text-primary text-base">qr_code</span>
                    <span class="font-mono font-bold text-primary text-sm">
                        @ViewBag.NuevoCodigo
                    </span>
                </div>
                <input type="hidden" name="Codprovee" value="@ViewBag.NuevoCodigo" />
            </div>

            @* Nombre *@
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase
                    tracking-widest mb-1.5">
                    Nombre <span class="text-red-500">*</span>
                </label>
                <input type="text" name="Nombre" required maxlength="200"
                       placeholder="Nombre completo del proveedor"
                       class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200
                dark:border-slate-700 rounded-lg text-sm px-3 py-2.5
                focus:border-primary focus:ring-primary" />
            </div>

            @* Teléfono + Correo *@
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase
                    tracking-widest mb-1.5">Teléfono</label>
                    <input type="text" name="Telefono" maxlength="15"
                           placeholder="+503 0000-0000"
                           class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200
                    dark:border-slate-700 rounded-lg text-sm px-3 py-2.5
                    focus:border-primary focus:ring-primary" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase
                    tracking-widest mb-1.5">Correo</label>
                    <input type="email" name="Email" maxlength="200"
                           placeholder="correo@empresa.com"
                           class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200
                    dark:border-slate-700 rounded-lg text-sm px-3 py-2.5
                    focus:border-primary focus:ring-primary" />
                </div>
            </div>

            @* Dirección *@
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase
                tracking-widest mb-1.5">Dirección</label>
                <textarea name="Direccion" rows="2" maxlength="300"
                      placeholder="Dirección física del proveedor…"
                      class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200
                dark:border-slate-700 rounded-lg text-sm px-3 py-2.5
                focus:border-primary focus:ring-primary resize-none">
            </textarea>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit"
                    class="flex-1 bg-primary hover:bg-primary/90 text-white font-bold
                py-3 rounded-lg transition-all uppercase text-xs tracking-widest">
                Registrar Proveedor
            </button>
            <button type="button" onclick="cerrarModal('modalCrear')"
                    class="px-6 py-3 border border-slate-200 dark:border-slate-700
                text-slate-500 hover:bg-slate-50 rounded-lg font-bold
                text-xs uppercase tracking-widest transition-all">
                Cancelar
            </button>
        </div>
    </form>
</div>
</div>

@* ══════════════════════════════════════════════════════════════════════
   MODAL — EDITAR
   ══════════════════════════════════════════════════════════════════════ *@
<div id="modalEditar"
     class="fixed inset-0 z-50 hidden items-center justify-center
    bg-black/50 backdrop-blur-sm p-4">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-lg">

        <div class="flex items-center justify-between px-6 py-4
            border-b border-slate-100 dark:border-slate-800">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white
                flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">edit</span>
                Editar Proveedor
            </h3>
            <button onclick="cerrarModal('modalEditar')"
                    class="text-slate-400 hover:text-slate-600 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <form asp-controller="Proveedor" asp-action="Editar" method="post"
              class="p-6 space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Codprovee" id="edit_Codprovee" />

            @* Código (solo display) *@
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase
                tracking-widest mb-1.5">Código</label>
                <input type="text" id="edit_CodigDisplay" readonly
                       class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200
                dark:border-slate-700 rounded-lg text-sm px-3 py-2.5
                text-primary font-mono font-bold cursor-not-allowed" />
                <p class="text-[10px] text-slate-400 mt-1">
                    El código no se puede modificar.
                </p>
            </div>

            @* Nombre *@
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase
                    tracking-widest mb-1.5">
                    Nombre <span class="text-red-500">*</span>
                </label>
                <input type="text" name="Nombre" id="edit_Nombre" required maxlength="200"
                       class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200
                dark:border-slate-700 rounded-lg text-sm px-3 py-2.5
                focus:border-primary focus:ring-primary" />
            </div>

            @* Teléfono + Correo *@
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase
                    tracking-widest mb-1.5">Teléfono</label>
                    <input type="text" name="Telefono" id="edit_Telefono" maxlength="15"
                           class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200
                    dark:border-slate-700 rounded-lg text-sm px-3 py-2.5
                    focus:border-primary focus:ring-primary" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase
                    tracking-widest mb-1.5">Correo</label>
                    <input type="email" name="Email" id="edit_Email" maxlength="200"
                           class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200
                    dark:border-slate-700 rounded-lg text-sm px-3 py-2.5
                    focus:border-primary focus:ring-primary" />
                </div>
            </div>

            @* Dirección *@
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase
                tracking-widest mb-1.5">Dirección</label>
                <textarea name="Direccion" id="edit_Direccion" rows="2" maxlength="300"
                      class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200
                dark:border-slate-700 rounded-lg text-sm px-3 py-2.5
                focus:border-primary focus:ring-primary resize-none">
            </textarea>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit"
                    class="flex-1 bg-primary hover:bg-primary/90 text-white font-bold
                py-3 rounded-lg transition-all uppercase text-xs tracking-widest">
                Guardar Cambios
            </button>
            <button type="button" onclick="cerrarModal('modalEditar')"
                    class="px-6 py-3 border border-slate-200 dark:border-slate-700
                text-slate-500 hover:bg-slate-50 rounded-lg font-bold
                text-xs uppercase tracking-widest transition-all">
                Cancelar
            </button>
        </div>
    </form>
</div>
</div>

@* ══════════════════════════════════════════════════════════════════════
   MODAL — DESACTIVAR
   ══════════════════════════════════════════════════════════════════════ *@
<div id="modalDesactivar"
     class="fixed inset-0 z-50 hidden items-center justify-center
    bg-black/50 backdrop-blur-sm p-4">
    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-sm">
        <div class="p-6 text-center space-y-4">

            <div class="size-16 rounded-full bg-red-100 flex items-center
                justify-center mx-auto">
                <span class="material-symbols-outlined text-red-600 text-3xl">
                    block
                </span>
            </div>

            <div>
                <h3 class="text-lg font-bold text-slate-900 dark:text-white">
                    ¿Desactivar proveedor?
                </h3>
                <p class="text-sm text-slate-500 mt-1">
                    Estás a punto de desactivar a
                    <span id="desact_Nombre"
                          class="font-bold text-slate-800 dark:text-slate-200"></span>.
                    No aparecerá en futuras compras.
                </p>
            </div>

            <form asp-controller="Proveedor" asp-action="Desactivar" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="codprovee" id="desact_Codprovee" />
                <div class="flex gap-3">
                    <button type="button" onclick="cerrarModal('modalDesactivar')"
                            class="flex-1 border border-slate-200 dark:border-slate-700
                        text-slate-600 hover:bg-slate-50 font-bold py-3
                        rounded-lg text-sm transition-all">
                        Cancelar
                    </button>
                    <button type="submit"
                            class="flex-1 bg-red-500 hover:bg-red-600 text-white
                        font-bold py-3 rounded-lg text-sm transition-all">
                        Sí, desactivar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════════════════════════════
   JAVASCRIPT
   ══════════════════════════════════════════════════════════════════════ *@
@section Scripts {
    <script>
        // ── Abrir / Cerrar ────────────────────────────────────────────────
        function abrirModal(id) {
            const m = document.getElementById(id);
            m.classList.remove('hidden');
            m.classList.add('flex');
            document.body.classList.add('overflow-hidden');
        }

        function cerrarModal(id) {
            const m = document.getElementById(id);
            m.classList.add('hidden');
            m.classList.remove('flex');
            document.body.classList.remove('overflow-hidden');
        }

        // Cerrar al hacer click en el overlay
        document.querySelectorAll('[id^="modal"]').forEach(modal => {
            modal.addEventListener('click', function (e) {
                if (e.target === this) cerrarModal(this.id);
            });
        });

        // Cerrar con Escape
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                ['modalCrear', 'modalEditar', 'modalDesactivar'].forEach(id => {
                    const m = document.getElementById(id);
                    if (m && !m.classList.contains('hidden')) cerrarModal(id);
                });
            }
        });

        // ── Crear ─────────────────────────────────────────────────────────
        function abrirModalCrear() {
            abrirModal('modalCrear');
        }

        // ── Editar ────────────────────────────────────────────────────────
        // Todos los datos vienen del HTML renderizado (igual que Productos)
        function abrirModalEditar(cod, nombre, telefono, email, direccion) {
            document.getElementById('edit_Codprovee').value    = cod;
            document.getElementById('edit_CodigDisplay').value = cod;
            document.getElementById('edit_Nombre').value       = nombre;
            document.getElementById('edit_Telefono').value     = telefono;
            document.getElementById('edit_Email').value        = email;
            document.getElementById('edit_Direccion').value    = direccion;
            abrirModal('modalEditar');
        }

        // ── Desactivar ────────────────────────────────────────────────────
        function abrirModalDesactivar(cod, nombre) {
            document.getElementById('desact_Codprovee').value  = cod;
            document.getElementById('desact_Nombre').textContent = nombre;
            abrirModal('modalDesactivar');
        }
    </script>
}