@model List<TechCore.Models.DTO.Producto.ProductoListDTO>

@{
    ViewData["Title"] = ViewData["Title"] ?? "Productos";
    ViewData["Active"] = ViewData["Active"] ?? "Productos";

    // Determina si el usuario puede editar
    bool puedeEditar = User.IsInRole("Administrador") || User.IsInRole("Bodega");
}

<style>
    .stock-alert {
        border-left: 4px solid #ef4444;
    }
</style>

<div class="space-y-8">

    @* ── Encabezado ───────────────────────────────────────── *@
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h1 class="text-3xl font-black tracking-tight text-slate-900 dark:text-white">
                @ViewData["Title"]
            </h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1">
                @(puedeEditar
                    ? "Gestión y control de stock en tiempo real."
                    : "Consulta de stock y precios disponibles.")
            </p>
        </div>

        @* Botón Nuevo — SOLO Bodega y Admin *@
        @if (puedeEditar)
        {
            <button onclick="abrirModalCrear()"
                    class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white px-6 py-3 rounded-lg font-bold transition-all shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined">add_circle</span>
                Nuevo Producto
            </button>
        }
    </div>

    @* ── Alertas TempData ─────────────────────────────────── *@
    @if (TempData["Exito"] != null)
    {
        <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <p class="text-sm font-bold text-emerald-700">@TempData["Exito"]</p>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-red-600">cancel</span>
            <p class="text-sm font-bold text-red-700">@TempData["Error"]</p>
        </div>
    }

    @* ── Búsqueda ─────────────────────────────────────────── *@
    <form method="get"
          class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <div class="flex flex-col sm:flex-row gap-3">
            <div class="flex-1 flex items-center bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg px-3">
                <span class="material-symbols-outlined text-slate-400 text-xl">search</span>
                <input type="text" name="buscar" value="@ViewData["Buscar"]"
                       placeholder="Buscar por código, descripción o categoría..."
                       class="bg-transparent border-none focus:ring-0 text-sm w-full py-2 px-2" />
            </div>
            <button type="submit"
                    class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white px-5 py-2.5 rounded-lg font-semibold transition-all">
                <span class="material-symbols-outlined text-sm">search</span>
                Buscar
            </button>
            @if (!string.IsNullOrWhiteSpace(ViewData["Buscar"]?.ToString()))
            {
                <a href="?"
                       class="inline-flex items-center gap-2 border border-slate-200 dark:border-slate-700 text-slate-500 hover:bg-slate-50 px-5 py-2.5 rounded-lg font-semibold transition-all">
                    <span class="material-symbols-outlined text-sm">close</span>
                    Limpiar
                </a>
            }
        </div>
    </form>

    @* ══════════════════════════════════════════════════════ *@
    @* GRID DE PRODUCTOS                                      *@
    @* ══════════════════════════════════════════════════════ *@
    @if (!Model.Any())
    {
        <div class="py-20 flex flex-col items-center gap-3 text-center">
            <span class="material-symbols-outlined text-6xl text-slate-200">inventory_2</span>
            <p class="text-lg font-bold text-slate-500">No se encontraron productos</p>
            <p class="text-sm text-slate-400">Intenta con otro término de búsqueda</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var item in Model)
            {
                var esStockCritico = item.Stock == 0;
                var esStockBajo = item.StockBajo && item.Stock > 0;
                var stockColorClass = esStockCritico
                    ? "text-red-600"
                    : esStockBajo ? "text-orange-500"
                    : "text-slate-900 dark:text-white";
                var cardBorderClass = esStockCritico || esStockBajo
                    ? "border-2 border-slate-100 dark:border-slate-800 stock-alert"
                    : "border border-slate-200 dark:border-slate-800";

                <div class="group bg-white dark:bg-slate-900 rounded-xl @cardBorderClass overflow-hidden hover:border-primary/50 transition-all hover:shadow-xl flex flex-col">

                    @* Área de ícono *@
                    <div class="relative h-40 bg-slate-50 dark:bg-slate-800 flex items-center justify-center overflow-hidden">
                        <span class="material-symbols-outlined text-7xl text-slate-200 group-hover:text-slate-300 transition-colors">
                            inventory_2
                        </span>

                        @* Badges de stock *@
                        @if (esStockCritico)
                        {
                            <div class="absolute top-2 right-2">
                                <span class="bg-red-500 text-white text-[10px] font-black px-2 py-1 rounded uppercase shadow">
                                    Agotado
                                </span>
                            </div>
                        }
                        else if (esStockBajo)
                        {
                            <div class="absolute top-2 right-2">
                                <span class="bg-orange-500 text-white text-[10px] font-black px-2 py-1 rounded uppercase shadow">
                                    Stock Bajo
                                </span>
                            </div>
                        }

                        @* Botones hover — SOLO Bodega y Admin *@
                        @if (puedeEditar)
                        {
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-3">
                                <button onclick="abrirModalEditar('@item.CodProd','@item.Descripcion',@(item.CodCategoria?.ToString() ?? "null"),'@item.PrecioCompra','@item.PrecioVenta',@item.StockMinimo)"
                                        class="bg-white text-slate-900 p-2 rounded-full hover:bg-primary hover:text-white transition-colors"
                                        title="Editar">
                                    <span class="material-symbols-outlined text-xl">edit</span>
                                </button>
                                <button onclick="abrirModalEliminar('@item.CodProd','@item.Descripcion')"
                                        class="bg-white text-slate-900 p-2 rounded-full hover:bg-red-500 hover:text-white transition-colors"
                                        title="Eliminar">
                                    <span class="material-symbols-outlined text-xl">delete</span>
                                </button>
                            </div>
                        }
                    </div>

                    @* Info del producto *@
                    <div class="p-4 flex flex-col flex-1">
                        <div class="flex justify-between items-start mb-1">
                            <p class="text-xs font-bold text-primary uppercase tracking-wider truncate">
                                @(item.Categoria ?? "Sin categoría")
                            </p>
                            <p class="text-[10px] font-medium text-slate-400 bg-slate-100 dark:bg-slate-800 px-1.5 py-0.5 rounded font-mono flex-shrink-0 ml-1">
                                @item.CodProd
                            </p>
                        </div>
                        <h3 class="font-bold text-slate-900 dark:text-white leading-snug mb-3 line-clamp-2">
                            @item.Descripcion
                        </h3>
                        <div class="mt-auto pt-3 border-t border-slate-100 dark:border-slate-800">
                            <div class="flex justify-between items-center">
                                <div>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Stock Actual</p>
                                    <p class="text-lg font-black @stockColorClass">@item.Stock uni.</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-[10px] text-slate-400 font-bold uppercase mb-0.5">Precio Venta</p>
                                    <p class="text-lg font-black text-slate-900 dark:text-white">
                                        $@item.PrecioVenta.ToString("N2")
                                    </p>
                                </div>
                            </div>
                            @* Barra de progreso stock *@
                            <div class="mt-3">
                                @{
                                    var porcentaje = item.StockMinimo > 0
                                        ? Math.Min((double)item.Stock / (item.StockMinimo * 3) * 100, 100)
                                        : 100;
                                    var barColor = esStockCritico ? "bg-red-500"
                                                 : esStockBajo ? "bg-orange-400"
                                                 : "bg-primary";
                                }
                                <div class="flex justify-between text-[10px] text-slate-400 mb-1">
                                    <span>Stock</span>
                                    <span>Mín: @item.StockMinimo</span>
                                </div>
                                <div class="h-1.5 bg-slate-100 dark:bg-slate-700 rounded-full overflow-hidden">
                                    <div class="h-full @barColor rounded-full transition-all"
                                         style="width: @porcentaje.ToString("F0")%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="flex items-center justify-between border-t border-slate-200 dark:border-slate-800 pt-4">
            <p class="text-sm text-slate-500">
                <span class="font-bold text-slate-900 dark:text-white">@Model.Count</span> productos
                @if (!string.IsNullOrWhiteSpace(ViewData["Buscar"]?.ToString()))
                {
                    <span> para "<span class="font-bold text-primary">@ViewData["Buscar"]</span>"</span>
                }
            </p>
            <p class="text-xs text-slate-400">
                <span class="text-red-500 font-bold">@Model.Count(p => p.StockBajo)</span> con stock bajo
            </p>
        </div>
    }
</div>

@* ══════════════════════════════════════════════════════════════════════ *@
@* MODALES — Solo se renderizan para Bodega y Admin                      *@
@* ══════════════════════════════════════════════════════════════════════ *@
@if (puedeEditar)
{
    @* ── MODAL CREAR ─────────────────────────────────────── *@
    <div id="modalCrear" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4">
        <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-lg">
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 dark:border-slate-800">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">add_box</span>
                    Nuevo Producto
                </h3>
                <button onclick="cerrarModal('modalCrear')" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <form asp-controller="Producto" asp-action="Crear" method="post" class="p-6 space-y-4">
                @Html.AntiForgeryToken()
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                            Código (autogenerado)
                        </label>
                        <div class="flex items-center gap-2 bg-slate-50 dark:bg-slate-800
                            border border-slate-200 dark:border-slate-700
                            rounded-lg px-3 py-2.5">
                            <span class="material-symbols-outlined text-primary text-base">qr_code</span>
                            <span class="font-mono font-bold text-primary text-sm">
                                @ViewBag.NuevoCodigo
                            </span>
                            <span class="ml-auto text-[10px] text-slate-400 uppercase tracking-widest">
                                autogenerado
                            </span>
                        </div>
                        <input type="hidden" name="CodProd" value="@ViewBag.NuevoCodigo" />
                    </div>
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Descripción</label>
                        <input type="text" name="Descripcion" maxlength="500" placeholder="Ej: Laptop HP 15 Core i5"
                               class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-primary focus:ring-primary" />
                    </div>
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Categoría</label>
                        <select name="CodCategoria"
                                class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-primary focus:ring-primary">
                            <option value="">Sin categoría</option>
                            @if (ViewBag.Categorias != null)
                            {
                                foreach (SelectListItem cat in ViewBag.Categorias as SelectList)
                                {
                                    <option value="@cat.Value">@cat.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                            Precio Compra <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 font-bold text-sm">$</span>
                            <input type="number" name="PrecioCompra" required step="0.01" min="0.01" placeholder="0.00"
                                   class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm pl-7 pr-3 py-2.5 focus:border-primary focus:ring-primary" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                            Precio Venta <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 font-bold text-sm">$</span>
                            <input type="number" name="PrecioVenta" required step="0.01" min="0.01" placeholder="0.00"
                                   class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm pl-7 pr-3 py-2.5 focus:border-primary focus:ring-primary" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Stock Inicial</label>
                        <input type="number" name="Stock" value="0" min="0"
                               class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-primary focus:ring-primary" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Stock Mínimo</label>
                        <input type="number" name="StockMinimo" value="5" min="0"
                               class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-primary focus:ring-primary" />
                    </div>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="submit"
                            class="flex-1 bg-primary hover:bg-primary/90 text-white font-bold py-3 rounded-lg transition-all uppercase text-xs tracking-widest">
                        Registrar Producto
                    </button>
                    <button type="button" onclick="cerrarModal('modalCrear')"
                            class="px-6 py-3 border border-slate-200 dark:border-slate-700 text-slate-500 hover:bg-slate-50 rounded-lg font-bold text-xs uppercase tracking-widest transition-all">
                        Cancelar
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* ── MODAL EDITAR ─────────────────────────────────────── *@
    <div id="modalEditar" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4">
        <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-lg">
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100 dark:border-slate-800">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">edit</span>
                    Editar Producto
                </h3>
                <button onclick="cerrarModal('modalEditar')" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <form asp-controller="Producto" asp-action="Editar" method="post" class="p-6 space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="CodProdOriginal" id="edit_CodProdOriginal" />
                <input type="hidden" name="EsEdicion" value="true" />
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Código</label>
                        <input type="text" name="CodProd" id="edit_CodProd" readonly
                               class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-3 py-2.5 text-slate-400 cursor-not-allowed" />
                        <p class="text-[10px] text-slate-400 mt-1">El código no se puede modificar.</p>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Descripción</label>
                        <input type="text" name="Descripcion" id="edit_Descripcion" maxlength="500"
                               class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-primary focus:ring-primary" />
                    </div>
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Categoría</label>
                        <select name="CodCategoria" id="edit_CodCategoria"
                                class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-primary focus:ring-primary">
                            <option value="">Sin categoría</option>
                            @if (ViewBag.Categorias != null)
                            {
                                foreach (SelectListItem cat in ViewBag.Categorias as SelectList)
                                {
                                    <option value="@cat.Value">@cat.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                            Precio Compra <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 font-bold text-sm">$</span>
                            <input type="number" name="PrecioCompra" id="edit_PrecioCompra" step="0.01" min="0.01"
                                   class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm pl-7 pr-3 py-2.5 focus:border-primary focus:ring-primary" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                            Precio Venta <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 font-bold text-sm">$</span>
                            <input type="number" name="PrecioVenta" id="edit_PrecioVenta" step="0.01" min="0.01"
                                   class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm pl-7 pr-3 py-2.5 focus:border-primary focus:ring-primary" />
                        </div>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1.5">Stock Mínimo</label>
                        <input type="number" name="StockMinimo" id="edit_StockMinimo" min="0"
                               class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-primary focus:ring-primary" />
                        <p class="text-[10px] text-slate-400 mt-1">⚠️ El stock se ajusta solo mediante compras y ventas.</p>
                    </div>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="submit"
                            class="flex-1 bg-primary hover:bg-primary/90 text-white font-bold py-3 rounded-lg transition-all uppercase text-xs tracking-widest">
                        Guardar Cambios
                    </button>
                    <button type="button" onclick="cerrarModal('modalEditar')"
                            class="px-6 py-3 border border-slate-200 dark:border-slate-700 text-slate-500 hover:bg-slate-50 rounded-lg font-bold text-xs uppercase tracking-widest transition-all">
                        Cancelar
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* ── MODAL ELIMINAR ───────────────────────────────────── *@
    <div id="modalEliminar" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4">
        <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-sm">
            <div class="p-6 text-center space-y-4">
                <div class="size-16 rounded-full bg-red-100 flex items-center justify-center mx-auto">
                    <span class="material-symbols-outlined text-red-600 text-3xl">delete_forever</span>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">¿Eliminar producto?</h3>
                    <p class="text-sm text-slate-500 mt-1">
                        Estás a punto de eliminar
                        <span id="eliminar_nombre" class="font-bold text-slate-800 dark:text-slate-200"></span>.
                        Esta acción no se puede deshacer.
                    </p>
                </div>
                <form asp-controller="Producto" asp-action="Eliminar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="codProd" id="eliminar_codProd" />
                    <div class="flex gap-3">
                        <button type="button" onclick="cerrarModal('modalEliminar')"
                                class="flex-1 border border-slate-200 dark:border-slate-700 text-slate-600 hover:bg-slate-50 font-bold py-3 rounded-lg text-sm transition-all">
                            Cancelar
                        </button>
                        <button type="submit"
                                class="flex-1 bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-lg text-sm transition-all">
                            Sí, eliminar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════════════ *@
@* JAVASCRIPT — Solo carga si puede editar                               *@
@* ══════════════════════════════════════════════════════════════════════ *@
@section Scripts {
    @if (puedeEditar)
    {
        <script>
            function abrirModal(id) {
                const modal = document.getElementById(id);
                modal.classList.remove('hidden');
                modal.classList.add('flex');
                document.body.classList.add('overflow-hidden');
            }

            function cerrarModal(id) {
                const modal = document.getElementById(id);
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                document.body.classList.remove('overflow-hidden');
            }

            document.querySelectorAll('[id^="modal"]').forEach(modal => {
                modal.addEventListener('click', function (e) {
                    if (e.target === this) cerrarModal(this.id);
                });
            });

            function abrirModalCrear() {
                abrirModal('modalCrear');
            }

            function abrirModalEditar(codProd, descripcion, codCategoria, precioCompra, precioVenta, stockMinimo) {
                document.getElementById('edit_CodProdOriginal').value = codProd;
                document.getElementById('edit_CodProd').value         = codProd;
                document.getElementById('edit_Descripcion').value     = descripcion;
                document.getElementById('edit_PrecioCompra').value    = precioCompra;
                document.getElementById('edit_PrecioVenta').value     = precioVenta;
                document.getElementById('edit_StockMinimo').value     = stockMinimo;

                const select = document.getElementById('edit_CodCategoria');
                if (select && codCategoria !== 'null') select.value = codCategoria;

                abrirModal('modalEditar');
            }

            function abrirModalEliminar(codProd, descripcion) {
                document.getElementById('eliminar_codProd').value       = codProd;
                document.getElementById('eliminar_nombre').textContent  = descripcion;
                abrirModal('modalEliminar');
            }

            document.addEventListener('keydown', e => {
                if (e.key === 'Escape') {
                    ['modalCrear','modalEditar','modalEliminar'].forEach(id => {
                        const m = document.getElementById(id);
                        if (m && !m.classList.contains('hidden')) cerrarModal(id);
                    });
                }
            });
        </script>
    }
}