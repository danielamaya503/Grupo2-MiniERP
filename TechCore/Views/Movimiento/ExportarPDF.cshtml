@model TechCore.Models.DTO.Movimiento.MovimientoPaginadoDTO
@{
    Layout = null;
    var nombreMes = ViewData["NombreMes"]?.ToString() ?? "";
    var balance   = Model.MontoEntradas - Model.MontoSalidas;
    var tipoPDF   = string.IsNullOrEmpty(Model.FiltroTipo)
                    ? "Entradas y Salidas"
                    : Model.FiltroTipo + "s";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <title>Movimientos @nombreMes @Model.Anio — TechCore</title>
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
            font-size: 10.5px;
            color: #1e293b;
            background: #fff;
        }

        .page {
            width: 100%;
            max-width: 1050px;
            margin: 0 auto;
            padding: 28px 36px 24px;
        }

        /* ══ ENCABEZADO ══════════════════════════════════ */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: stretch;
            margin-bottom: 20px;
            padding-bottom: 18px;
            border-bottom: 3px solid #0f172a;
        }
        .header-left { display: flex; align-items: center; gap: 16px; }

        .logo-wrap {
            width: 64px; height: 64px;
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
            padding: 4px;
            background: #fff;
            flex-shrink: 0;
        }
        .logo-wrap img {
            width: 100%; height: 100%;
            object-fit: contain;
            display: block;
        }

        .empresa-nombre {
            font-size: 20px; font-weight: 800;
            color: #0f172a; letter-spacing: -0.5px;
        }
        .empresa-slogan {
            font-size: 9.5px; color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.08em; font-weight: 600;
        }
        .empresa-datos {
            margin-top: 5px; font-size: 9px;
            color: #94a3b8; line-height: 1.5;
        }
        .empresa-datos strong { color: #64748b; }

        .header-divider {
            width: 1px; background: #e2e8f0; margin: 0 20px;
        }

        .header-right {
            display: flex; flex-direction: column;
            justify-content: center;
            text-align: right; min-width: 200px;
        }
        .doc-number {
            display: inline-block;
            background: #f1f5f9; border: 1px solid #e2e8f0;
            border-radius: 4px; padding: 2px 8px;
            font-size: 9px; font-family: 'Courier New', monospace;
            color: #64748b; margin-bottom: 4px;
        }
        .doc-tipo {
            font-size: 15px; font-weight: 800;
            color: #0f172a; text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .doc-periodo {
            font-size: 11px; color: #3b82f6;
            font-weight: 700; margin-top: 2px;
        }
        .doc-meta {
            margin-top: 7px; font-size: 9px;
            color: #94a3b8; line-height: 1.7;
        }
        .doc-meta strong { color: #64748b; }

        /* ══ FRANJA TÍTULO ═══════════════════════════════ */
        .title-bar {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
            color: #fff;
            padding: 9px 16px;
            border-radius: 8px;
            margin-bottom: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .title-bar .tb-left {
            font-size: 12px; font-weight: 700;
        }
        .title-bar .tb-left span {
            font-size: 9.5px; font-weight: 400;
            opacity: 0.65; margin-left: 8px;
        }
        .title-bar .tb-right {
            font-size: 8.5px; opacity: 0.65;
            text-align: right; line-height: 1.6;
        }

        /* ══ KPIs ════════════════════════════════════════ */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 8px;
            margin-bottom: 16px;
        }
        .kpi {
            border-radius: 8px; padding: 10px 12px;
            border: 1px solid #e2e8f0;
            position: relative; overflow: hidden;
        }
        .kpi::before {
            content: ''; position: absolute;
            top: 0; left: 0; right: 0; height: 3px;
        }
        .kpi.verde::before  { background: #22c55e; }
        .kpi.rojo::before   { background: #ef4444; }
        .kpi.morado::before { background: #8b5cf6; }
        .kpi.gris::before   { background: #94a3b8; }

        .kpi-label {
            font-size: 8px; font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: #94a3b8; margin-bottom: 4px;
        }
        .kpi-valor { font-size: 15px; font-weight: 800; line-height: 1; }
        .kpi.verde  .kpi-valor { color: #15803d; }
        .kpi.rojo   .kpi-valor { color: #b91c1c; }
        .kpi.morado .kpi-valor { color: #6d28d9; }
        .kpi.gris   .kpi-valor { color: #475569; }
        .kpi-sub { font-size: 8px; color: #94a3b8; margin-top: 3px; }

        /* ══ TABLA ═══════════════════════════════════════ */
        .table-wrap {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 14px;
        }
        table { width: 100%; border-collapse: collapse; font-size: 9.5px; }

        thead tr { background: #0f172a; color: #fff; }
        thead th {
            padding: 7px 9px; text-align: left;
            font-size: 8px; font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            white-space: nowrap;
        }
        thead th.r { text-align: right; }

        tbody tr { border-bottom: 1px solid #f1f5f9; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:nth-child(even) { background: #f8fafc; }
        tbody td { padding: 5.5px 9px; vertical-align: middle; line-height: 1.3; }
        tbody td.r { text-align: right; font-weight: 600; }
        tbody td.mono {
            font-family: 'Courier New', monospace; font-size: 9px;
        }

        .badge {
            display: inline-flex; align-items: center; gap: 3px;
            padding: 2px 7px; border-radius: 20px;
            font-size: 7.5px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.05em;
        }
        .badge-e { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
        .badge-s { background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca; }

        tfoot tr { background: #0f172a; color: #fff; }
        tfoot td { padding: 7px 9px; font-weight: 700; font-size: 10px; }
        tfoot td.r { text-align: right; font-size: 12px; }

        /* ══ NOTA ════════════════════════════════════════ */
        .doc-note {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-left: 3px solid #3b82f6;
            border-radius: 0 6px 6px 0;
            padding: 7px 12px;
            margin-bottom: 14px;
            font-size: 8.5px; color: #64748b;
            display: flex; gap: 8px;
        }
        .doc-note strong { color: #1e40af; }

        /* ══ EMPTY ═══════════════════════════════════════ */
        .empty-state {
            text-align: center; padding: 40px; color: #94a3b8;
        }

        /* ══ PIE DE PÁGINA ═══════════════════════════════ */
        .footer {
            border-top: 1.5px solid #e2e8f0;
            padding-top: 10px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }
        .footer-left {
            font-size: 8.5px; color: #94a3b8; line-height: 1.6;
        }
        .footer-left strong { color: #64748b; }
        .footer-firma {
            width: 130px;
            border-top: 1px solid #64748b;
            text-align: center;
            padding-top: 4px;
            font-size: 8px; color: #94a3b8;
        }

        /* ══ BOTÓN IMPRIMIR (no aparece al imprimir) ═════ */
        .btn-print {
            position: fixed; top: 20px; right: 20px;
            display: flex; align-items: center; gap: 8px;
            background: #0f172a; color: #fff;
            border: none; cursor: pointer;
            padding: 10px 18px; border-radius: 8px;
            font-size: 13px; font-weight: 700;
            box-shadow: 0 4px 16px rgba(0,0,0,.25);
            z-index: 999; transition: background .2s;
            font-family: 'Segoe UI', sans-serif;
        }
        .btn-print:hover { background: #1e3a5f; }

        /* ══ PRINT ═══════════════════════════════════════ */
        @@media print {
            body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .btn-print { display: none !important; }
            @@page { size: A4 landscape; margin: 12mm 16mm; }
            table  { page-break-inside: auto; }
            tr     { page-break-inside: avoid; }
            thead  { display: table-header-group; }
            tfoot  { display: table-footer-group; }
            .table-wrap { border-radius: 0; }
            .title-bar  { border-radius: 0; }
        }
    </style>
</head>
<body>

    <button class="btn-print" onclick="window.print()">
        🖨 Guardar / Imprimir PDF
    </button>

    <div class="page">

        @* ── ENCABEZADO CORPORATIVO ──────────────────── *@
        <div class="header">
            <div class="header-left">
                <div class="logo-wrap">
                    <img src="@Url.Content("~/img/techcore/logo-techcore.webp")"
                         alt="Logo TechCore" />
                </div>
                <div>
                    <div class="empresa-nombre">TechCore</div>
                    <div class="empresa-slogan">MiniERP · Sistema de Gestión</div>
                    <div class="empresa-datos">
                        Sistema de Inventario y Ventas<br />
                        Generado por: <strong>@User.Identity?.Name</strong>
                    </div>
                </div>
            </div>

            <div class="header-divider"></div>

            <div class="header-right">
                <span class="doc-number">
                    DOC-@DateTime.Now.ToString("yyyyMMdd")-@Model.Mes.ToString("D2")
                </span>
                <div class="doc-tipo">Historial de Movimientos</div>
                <div class="doc-periodo">@tipoPDF - @nombreMes</div>
                <div class="doc-meta">
                    <strong>Fecha emisión:</strong>
                    @DateTime.Now.ToString("dd/MM/yyyy HH:mm")<br />
                    <strong>Total registros:</strong> @Model.TotalRegistros<br />
                    <strong>Período:</strong> @nombreMes @Model.Anio
                </div>
            </div>
        </div>

        @* ── FRANJA TÍTULO ───────────────────────────── *@
        <div class="title-bar">
            <div class="tb-left">
                 Reporte de Movimientos de Inventario
                <span>Compras (Entradas) y Ventas (Salidas)</span>
            </div>
            <div class="tb-right">
                Período: @nombreMes @Model.Anio<br />
                Clasificación: @tipoPDF
            </div>
        </div>

        @* ── KPIs ────────────────────────────────────── *@
        <div class="kpi-grid">
            <div class="kpi verde">
                <div class="kpi-label"> Entradas</div>
                <div class="kpi-valor">@Model.TotalEntradas</div>
                <div class="kpi-sub">registros de compra</div>
            </div>
            <div class="kpi rojo">
                <div class="kpi-label">Salidas</div>
                <div class="kpi-valor">@Model.TotalSalidas</div>
                <div class="kpi-sub">registros de venta</div>
            </div>
            <div class="kpi verde">
                <div class="kpi-label">Monto Entradas</div>
                <div class="kpi-valor">$@Model.MontoEntradas.ToString("N2")</div>
                <div class="kpi-sub">total comprado</div>
            </div>
            <div class="kpi rojo">
                <div class="kpi-label">Monto Salidas</div>
                <div class="kpi-valor">$@Model.MontoSalidas.ToString("N2")</div>
                <div class="kpi-sub">total vendido</div>
            </div>
            <div class="kpi @(balance >= 0 ? "morado" : "gris")">
                <div class="kpi-label"> Balance</div>
                <div class="kpi-valor">
                    @(balance >= 0 ? "+" : "")$@Math.Abs(balance).ToString("N2")
                </div>
                <div class="kpi-sub">entradas - salidas</div>
            </div>
        </div>

        @* ── TABLA ──────────────────────────────────── *@
        @if (!Model.Movimientos.Any())
        {
            <div class="empty-state">
                <p style="font-size:40px; margin-bottom:8px">📭</p>
                <p>No se encontraron movimientos para
                   <strong>@nombreMes @Model.Anio</strong></p>
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th style="width:70px">Fecha</th>
                            <th style="width:56px">Tipo</th>
                            <th style="width:84px">N° Documento</th>
                            <th style="width:74px">Código</th>
                            <th>Descripción del Producto</th>
                            <th class="r" style="width:48px">Cant.</th>
                            <th class="r" style="width:76px">P. Unitario</th>
                            <th class="r" style="width:82px">Subtotal</th>
                            <th style="width:115px">Proveedor / Cliente</th>
                            <th style="width:88px">Responsable</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mov in Model.Movimientos)
                        {
                            var esE  = mov.Tipo == "Entrada";
                            var pref = esE ? "OC-" : "VT-";
                            <tr>
                                <td>
                                    @mov.Fecha.ToString("dd/MM/yyyy")<br />
                                    <span style="color:#94a3b8; font-size:8px">
                                        @mov.Fecha.ToString("HH:mm")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(esE ? "badge-e" : "badge-s")">
                                        @mov.Tipo
                                    </span>
                                </td>
                                <td class="mono">@pref@mov.Referencia.ToString()</td>
                                <td class="mono" style="color:#64748b">@mov.CodProd</td>
                                <td style="color:#334155">@mov.Descripcion</td>
                                <td class="r">@mov.Cantidad.ToString("N0")</td>
                                <td class="r" style="color:#64748b">
                                    $@mov.Precio.ToString("N2")
                                </td>
                                <td class="r">$@mov.Subtotal.ToString("N2")</td>
                                <td style="font-size:9px; color:#475569">@mov.Origen</td>
                                <td style="font-size:9px; color:#64748b">
                                    @(mov.UsuarioNombre ?? "Sistema")
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="5" style="font-size:8.5px; opacity:.7">
                                @Model.TotalRegistros registro(s) — @nombreMes @Model.Anio
                            </td>
                            <td class="r">
                                @Model.Movimientos.Sum(m => m.Cantidad).ToString("N0")
                            </td>
                            <td></td>
                            <td class="r">
                                $@Model.Movimientos.Sum(m => m.Subtotal).ToString("N2")
                            </td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="doc-note">
                <span>ℹ️</span>
                <div>
                    <strong>Nota:</strong>
                    Las <strong>Entradas</strong> corresponden a órdenes de compra con
                    estado activo. Las <strong>Salidas</strong> corresponden a ventas
                    no anuladas. Los montos reflejan precios al momento de
                    cada transacción.
                </div>
            </div>
        }

        @* ── PIE DE PÁGINA ───────────────────────────── *@
        <div class="footer">
            <div class="footer-left">
                <strong>TechCore MiniERP</strong> · Sistema de Gestión de Inventario<br />
                Generado el
                @DateTime.Now.ToString("dd 'de' MMMM 'de' yyyy",
                    new System.Globalization.CultureInfo("es-ES"))
                a las @DateTime.Now.ToString("HH:mm") ·
                Usuario: <strong>@User.Identity?.Name</strong><br />
                Documento de uso interno — confidencial
            </div>
            <div>
                <div class="footer-firma">Responsable del período</div>
            </div>
        </div>

    </div>

    <script>
        // Abre el diálogo de impresión automáticamente
        window.addEventListener('load', function () {
            setTimeout(function () {
                window.print();
            }, 800); // delay para que cargue el logo
            window.addEventListener('afterprint', function () {
                window.close();
            });
        });
    </script>

</body>
</html>